{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(npx prisma generate*)",
      "Bash(npx prisma migrate dev*)",
      "Bash(npx prisma studio*)",
      "Bash(npx prisma db push*)",
      "Bash(npx vercel *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npx prisma migrate reset *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true",
            "condition": "{{ file_path matches '\\.(ts|tsx|js|jsx)$' }}"
          }
        ]
      }
    ]
  }
}
